<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.RadioMenuItem?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>


<AnchorPane id="AnchorPane" prefHeight="700.0" prefWidth="1000.0"  stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"   fx:controller="scenebuildera.TestController">
    <children>
        <BorderPane prefHeight="700.0" prefWidth="1000.0"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <top>
                <VBox>
                    <children>

                        <MenuBar fx:id="menubar" styleClass="top-menu-bar">
                            <menus>

                                <Menu text="File">
                                    <items>
                                        <MenuItem fx:id="exit" onAction="#exitHandle" text="Exit" />
                                    </items>
                                </Menu>

                                <Menu text="Appearance">
                                    <items>

                                        <Menu text="Font Family">
                                            <items>
                                                <RadioMenuItem fx:id="arialMenu" onAction="#fontFamilyHandle" selected="true" text="Arial">
                                                    <toggleGroup>
                                                        <ToggleGroup fx:id="tg2" />
                                                    </toggleGroup>
                                                </RadioMenuItem>
                                                <RadioMenuItem fx:id="timesMenu" onAction="#fontFamilyHandle" text="Times New Roman" toggleGroup="$tg2" />
                                                <RadioMenuItem fx:id="sansMenu" onAction="#fontFamilyHandle" text="Sans Serif" toggleGroup="$tg2" />
                                            </items>
                                        </Menu>

                                        <Menu text="Font Size">
                                            <items>
                                                <RadioMenuItem fx:id="smallMenu" onAction="#fontSizeHandle" text="Small">
                                                    <toggleGroup>
                                                        <ToggleGroup fx:id="tg3" />
                                                    </toggleGroup>
                                                </RadioMenuItem>
                                                <RadioMenuItem fx:id="mediumMenu" onAction="#fontSizeHandle" selected="true" text="Medium" toggleGroup="$tg3" />
                                                <RadioMenuItem fx:id="largeMenu" onAction="#fontSizeHandle" text="Large" toggleGroup="$tg3" />
                                            </items>
                                        </Menu>

                                        <Menu text="Font Style">
                                            <items>
                                                <MenuItem text="Bold" />
                                                <MenuItem text="Italic" />
                                            </items>
                                        </Menu>

                                    </items>
                                </Menu>

                                <Menu text="Help">
                                    <items>
                                        <MenuItem fx:id="about" onAction="#aboutHandle" text="About" />
                                    </items>
                                </Menu>

                            </menus>
                        </MenuBar>

                        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="header-bar">
                            <children>
                                <Label styleClass="header-title" text="Job Application System" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label text="Applicant Form" />
                            </children>
                            <padding>
                                <Insets top="12.0" right="15.0" bottom="12.0" left="15.0" />
                            </padding>
                        </HBox>

                    </children>
                </VBox>
            </top>

            <center>
                <HBox spacing="20.0" styleClass="main-content">
                    <children>

                        <!-- Left side -->
                        <VBox spacing="15.0" styleClass="left-panel" prefWidth="300.0">
                            <children>

                                <Label styleClass="section-title" text="Applicant Profile" />
                                <Separator />

                                <StackPane styleClass="image-frame">
                                    <children>
                                        <ImageView fx:id="imgView" fitHeight="140.0" fitWidth="140.0" preserveRatio="true" />
                                    </children>
                                </StackPane>

                                <Button fx:id="uploadImage" onAction="#uploadImageHandle" text="Upload Image" />

                                <Label text="Background Color" />
                                <ColorPicker fx:id="colorPicker" />

                            </children>
                            <padding>
                                <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
                            </padding>
                        </VBox>

                        <!-- Right side -->
                        <VBox spacing="15.0" styleClass="right-panel" HBox.hgrow="ALWAYS">
                            <children>

                                <Label styleClass="section-title" text="Application Form" />
                                <Separator />

                                <GridPane hgap="12.0" vgap="12.0">
                                    <children>

                                        <Label text="Full Name" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <TextField fx:id="fullName" promptText="Enter full name"
                                                   GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                        <Label text="Address" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <TextField fx:id="address" promptText="Enter address"
                                                   GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                        <Label text="Phone Number" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                        <TextField fx:id="phoneNumber" promptText="Enter phone number"
                                                   GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                        <Label text="Birthdate" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                        <DatePicker fx:id="datePicker"
                                                    GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                    </children>
                                </GridPane>

                                <Label text="Marital Status" />
                                <HBox spacing="20.0">
                                    <children>
                                        <RadioButton fx:id="single" text="Single">
                                            <toggleGroup>
                                                <ToggleGroup fx:id="tg" />
                                            </toggleGroup>
                                        </RadioButton>
                                        <RadioButton fx:id="married" text="Married" toggleGroup="$tg" />
                                        <RadioButton fx:id="divorced" text="Divorced" toggleGroup="$tg" />
                                    </children>
                                </HBox>

                                <Label text="Skills" />
                                <HBox spacing="15.0">
                                    <children>

                                        <VBox spacing="8.0">
                                            <children>
                                                <Label text="Available Skills" />
                                                <ListView fx:id="availableSkills" prefHeight="140.0" prefWidth="180.0" />
                                            </children>
                                        </VBox>

                                        <VBox alignment="CENTER" spacing="10.0">
                                            <children>
                                                <Button fx:id="addSkill" onAction="#addSkillHandle" text="&gt;&gt;" />
                                                <Button fx:id="removeSkill" onAction="#removeSkillHandle" text="&lt;&lt;" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="8.0">
                                            <children>
                                                <Label text="Selected Skills" />
                                                <ListView fx:id="selectedSkills" prefHeight="140.0" prefWidth="180.0" />
                                            </children>
                                        </VBox>

                                    </children>
                                </HBox>

                                <Label text="Cover Letter" />
                                <TextArea fx:id="textArea"
                                          prefHeight="120.0"
                                          wrapText="true"
                                          promptText="Write cover letter here or upload it from file..." />

                                <Label text="Font Size" />
                                <Slider fx:id="slider"
                                        min="10.0"
                                        max="30.0"
                                        value="12.0"
                                        showTickLabels="true"
                                        showTickMarks="true"
                                        onMouseDragged="#sliderHandle" />

                                <HBox spacing="10.0" alignment="CENTER_RIGHT">
                                    <children>
                                        <Button fx:id="uploadCoverLetter" onAction="#uploadCoverLetterHandle" text="Upload Cover Letter" />
                                        <Button fx:id="save" onAction="#saveHandle" text="Save" />
                                    </children>
                                </HBox>

                            </children>
                            <padding>
                                <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
                            </padding>
                        </VBox>

                    </children>

                    <padding>
                        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
                    </padding>
                </HBox>
            </center>

        </BorderPane>
    </children> 
</AnchorPane>
